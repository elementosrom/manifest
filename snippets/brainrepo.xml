<?xml version="1.0" encoding="UTF-8"?>
<manifest>

  <remote name="brainrepo"
          fetch="https://github.com/brainrepoCAF"
          revision="uranium" />

  <remote name="brainrepo-gitlab"
          fetch="https://gitlab.com/brainrepoCAF"
          revision="uranium" />

  <!-- Remove repos-->
  <remove-project name="device/amlogic/yukawa" />
